{
  "name": "timeslottr",
  "version": "1.0.0",
  "description": "A zero-dependency TypeScript library for generating time slots with timezone support, buffers, exclusions, and overlap detection.",
  "keywords": [
    "timeslot",
    "timeslots",
    "scheduling",
    "scheduler",
    "time",
    "date",
    "timezone",
    "availability",
    "calendar",
    "appointments",
    "booking",
    "slots"
  ],
  "license": "MIT",
  "author": "Tilo Mitra <tilomitra@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/tilomitra/timeslottr.git"
  },
  "homepage": "https://timeslottr.vercel.app",
  "bugs": {
    "url": "https://github.com/tilomitra/timeslottr/issues"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@vitest/coverage-v8": "^1.6.1",
    "tsup": "^8.0.1",
    "typescript": "^5.4.4",
    "vitest": "^1.5.0"
  }
}
